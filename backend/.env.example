# Database (Railway fournit automatiquement cette variable)
DATABASE_URL="postgresql://username:password@localhost:5432/dmaic_db?schema=public"

# JWT (IMPORTANT: utilisez une clé forte en production)
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Server
PORT=3001
NODE_ENV=production

# Frontend URL (pour CORS - URL Vercel de votre frontend)
FRONTEND_URL=https://votre-app.vercel.app

# Email (optionnel - pour les notifications par email)
RESEND_API_KEY=
EMAIL_FROM="DMAIC App <noreply@votre-domaine.com>"
